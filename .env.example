# ──────────────────────────────────────
# Equisium Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer le fichier .env (déjà ignoré par .gitignore).
# ──────────────────────────────────────

# Port d'écoute du serveur Express
PORT=3000

# Connexion MongoDB Atlas
# Récupérer l'URI dans Atlas > Connect > Drivers
# Remplacer <username>, <password> par tes identifiants Atlas
# La base "equisium" sera utilisée explicitement (ajoutée après le slash final avant les "?")
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-url>/equisium?retryWrites=true&w=majority

# Secret utilisé pour signer et vérifier les tokens JWT
# Générer une valeur forte et aléatoire, par exemple avec :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Origine autorisée pour les requêtes CORS (URL du frontend en développement)
CORS_ORIGIN=http://localhost:5173
